///main
block Main {
    ///device_select
    device_select: DeviceSelect @ 0x0,
    ///eth100g_regs
    eth100g_regs: Eth100GRegs @ 0x2000000,
    ///eth400g_p1
    eth400g_p1: Eth400GP1 @ 0x2040000,
    ///ethgpiobr
    ethgpiobr: Ethgpiobr @ 0x2840000,
    ///ethgpiotl
    ethgpiotl: Ethgpiotl @ 0x2880000,
    ///gpio_iotile_bl
    gpio_iotile_bl: GpioIotileBl @ 0x28c0000,
    ///gpio_iotile_br
    gpio_iotile_br: GpioIotileBr @ 0x2900000,
    ///gpio_iotile_tr
    gpio_iotile_tr: GpioIotileTr @ 0x2940000,
    ///gpio_iotile_tl
    gpio_iotile_tl: GpioIotileTl @ 0x2980000,
    ///eth100g_regs_rot
    eth100g_regs_rot: Eth100GRegsRot @ 0x29c0000,
    ///serdes
    serdes: Serdes @ 0x3000000,
    ///pipes
    pipes: Pipes[0x4; 0x1000000] @ 0x4000000,
}

///main.device_select
block DeviceSelect {
    ///pcie_bar01_regs
    pcie_bar01_regs: PcieBar01Regs @ 0x0,
    ///misc_regs
    misc_regs: MiscRegs @ 0x80000,
    ///misc_tv80_regs
    misc_tv80_regs: MiscTv80Regs @ 0x84000,
    ///mbc
    mbc: Mbc @ 0x180000,
    ///pbc
    pbc: Pbc @ 0x200000,
    ///cbc
    cbc: Cbc @ 0x280000,
    ///tbc
    tbc: Tbc @ 0x300000,
    ///lfltr
    lfltr: Lfltr[0x4; 0x80000] @ 0x400000,
    ///tm_top
    tm_top: TmTop @ 0x800000,
}

///main.device_select.cbc
block Cbc {
    ///cbc_cbus
    cbc_cbus: CbcCbus @ 0x0,
    ///cbc_wl0_tx_dr
    cbc_wl0_tx_dr: CbcWl0TxDr @ 0x400,
    ///cbc_wl0_cpl_dr
    cbc_wl0_cpl_dr: CbcWl0CplDr @ 0x440,
    ///cbc_wl1_tx_dr
    cbc_wl1_tx_dr: CbcWl1TxDr @ 0x480,
    ///cbc_wl1_cpl_dr
    cbc_wl1_cpl_dr: CbcWl1CplDr @ 0x4c0,
    ///cbc_rb0_tx_dr
    cbc_rb0_tx_dr: CbcRb0TxDr @ 0x500,
    ///cbc_rb0_cpl_dr
    cbc_rb0_cpl_dr: CbcRb0CplDr @ 0x540,
    ///cbc_rb1_tx_dr
    cbc_rb1_tx_dr: CbcRb1TxDr @ 0x580,
    ///cbc_rb1_cpl_dr
    cbc_rb1_cpl_dr: CbcRb1CplDr @ 0x5c0,
    ///cbc_lq_fm_dr
    cbc_lq_fm_dr: CbcLqFmDr @ 0x600,
    ///cbc_lq_rx_dr
    cbc_lq_rx_dr: CbcLqRxDr @ 0x640,
}

///main.device_select.cbc.cbc_cbus
block CbcCbus {
    ///jbay_reg.device_select.cbc.cbc_cbus.scratch
    scratch: CbcCbus_Scratch[0x4; 0x4] @ 0x0,
    ///jbay_reg.device_select.cbc.cbc_cbus.ctrl
    ctrl: CbcCbus_Ctrl @ 0x10,
    ///jbay_reg.device_select.cbc.cbc_cbus.flush
    flush: CbcCbus_Flush @ 0x14,
    ///jbay_reg.device_select.cbc.cbc_cbus.link_down
    link_down: CbcCbus_LinkDown @ 0x18,
    ///jbay_reg.device_select.cbc.cbc_cbus.arb_ctrl
    arb_ctrl: CbcCbus_ArbCtrl @ 0x1c,
    ///jbay_reg.device_select.cbc.cbc_cbus.pri_ctrl
    pri_ctrl: CbcCbus_PriCtrl @ 0x20,
    ///jbay_reg.device_select.cbc.cbc_cbus.intr_stat0
    intr_stat0: CbcCbus_IntrStat0 @ 0x24,
    ///jbay_reg.device_select.cbc.cbc_cbus.intr_stat1
    intr_stat1: CbcCbus_IntrStat1 @ 0x28,
    ///jbay_reg.device_select.cbc.cbc_cbus.intr_en0_0
    intr_en0_0: CbcCbus_IntrEn00 @ 0x2c,
    ///jbay_reg.device_select.cbc.cbc_cbus.intr_en0_1
    intr_en0_1: CbcCbus_IntrEn01 @ 0x30,
    ///jbay_reg.device_select.cbc.cbc_cbus.intr_en0_2
    intr_en0_2: CbcCbus_IntrEn02 @ 0x34,
    ///jbay_reg.device_select.cbc.cbc_cbus.intr_en0_3
    intr_en0_3: CbcCbus_IntrEn03 @ 0x38,
    ///jbay_reg.device_select.cbc.cbc_cbus.intr_en1_0
    intr_en1_0: CbcCbus_IntrEn10 @ 0x3c,
    ///jbay_reg.device_select.cbc.cbc_cbus.intr_en1_1
    intr_en1_1: CbcCbus_IntrEn11 @ 0x40,
    ///jbay_reg.device_select.cbc.cbc_cbus.intr_en1_2
    intr_en1_2: CbcCbus_IntrEn12 @ 0x44,
    ///jbay_reg.device_select.cbc.cbc_cbus.intr_en1_3
    intr_en1_3: CbcCbus_IntrEn13 @ 0x48,
    ///jbay_reg.device_select.cbc.cbc_cbus.freeze_en0
    freeze_en0: CbcCbus_FreezeEn0 @ 0x4c,
    ///jbay_reg.device_select.cbc.cbc_cbus.freeze_en1
    freeze_en1: CbcCbus_FreezeEn1 @ 0x50,
    ///jbay_reg.device_select.cbc.cbc_cbus.intr_inj
    intr_inj: CbcCbus_IntrInj @ 0x54,
    ///jbay_reg.device_select.cbc.cbc_cbus.wl_tx_dr_rd_err_log
    wl_tx_dr_rd_err_log: WlTxDrRdErrLog[0x2; 0x4] @ 0x58,
    ///jbay_reg.device_select.cbc.cbc_cbus.rb_tx_dr_rd_err_log
    rb_tx_dr_rd_err_log: CbcCbus_RbTxDrRdErrLog[0x2; 0x4] @ 0x60,
    ///jbay_reg.device_select.cbc.cbc_cbus.lq_fm_dr_rd_err_log
    lq_fm_dr_rd_err_log: LqFmDrRdErrLog @ 0x68,
    ///jbay_reg.device_select.cbc.cbc_cbus.controller_mbe_log
    controller_mbe_log: CbcCbus_ControllerMbeLog @ 0x6c,
    ///jbay_reg.device_select.cbc.cbc_cbus.controller_sbe_log
    controller_sbe_log: CbcCbus_ControllerSbeLog @ 0x70,
    ///jbay_reg.device_select.cbc.cbc_cbus.parity_err_log
    parity_err_log: CbcCbus_ParityErrLog[0x7; 0x4] @ 0x80,
    ///host_creq_credit
    host_creq_credit: CbcCbus_HostCreqCredit @ 0xa0,
    ///wl_creq_credit
    wl_creq_credit: WlCreqCredit @ 0xb0,
    ///rb_creq_credit
    rb_creq_credit: CbcCbus_RbCreqCredit @ 0xc0,
    ///jbay_reg.device_select.cbc.cbc_cbus.lq_slot_credit
    lq_slot_credit: LqSlotCredit @ 0xcc,
    ///jbay_reg.device_select.cbc.cbc_cbus.host_slave_credit
    host_slave_credit: CbcCbus_HostSlaveCredit @ 0xd0,
    ///dma_log
    dma_log: CbcCbus_DmaLog @ 0xe0,
    ///jbay_reg.device_select.cbc.cbc_cbus.mst_ctrl_log
    mst_ctrl_log: CbcCbus_MstCtrlLog @ 0xec,
}

///main.device_select.cbc.cbc_cbus.dma_log
block CbcCbus_DmaLog {
    ///jbay_reg.device_select.cbc.cbc_cbus.dma_log.dma_log_0_3
    dma_log_0_3: DmaLog03 @ 0x0,
    ///jbay_reg.device_select.cbc.cbc_cbus.dma_log.dma_log_1_3
    dma_log_1_3: DmaLog13 @ 0x4,
    ///jbay_reg.device_select.cbc.cbc_cbus.dma_log.dma_log_2_3
    dma_log_2_3: DmaLog23 @ 0x8,
}

///main.device_select.cbc.cbc_cbus.host_creq_credit
block CbcCbus_HostCreqCredit {
    ///jbay_reg.device_select.cbc.cbc_cbus.host_creq_credit.host_creq_credit_0_3
    host_creq_credit_0_3: HostCreqCredit03 @ 0x0,
    ///jbay_reg.device_select.cbc.cbc_cbus.host_creq_credit.host_creq_credit_1_3
    host_creq_credit_1_3: HostCreqCredit13 @ 0x4,
    ///jbay_reg.device_select.cbc.cbc_cbus.host_creq_credit.host_creq_credit_2_3
    host_creq_credit_2_3: HostCreqCredit23 @ 0x8,
}

