    ///jbay_reg.device_select.mbc.mbc_mbus.ts_timer
    ts_timer: TsTimer @ 0x60,
    ///jbay_reg.device_select.mbc.mbc_mbus.ts_capture
    ts_capture: TsCapture @ 0x64,
    ///global_ts_value
