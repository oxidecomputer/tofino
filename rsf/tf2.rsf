block CbcCbus_RbCreqCredit {
    ///jbay_reg.device_select.cbc.cbc_cbus.rb_creq_credit.rb_creq_credit_0_3
    rb_creq_credit_0_3: RbCreqCredit03 @ 0x0,
    ///jbay_reg.device_select.cbc.cbc_cbus.rb_creq_credit.rb_creq_credit_1_3
    rb_creq_credit_1_3: RbCreqCredit13 @ 0x4,
    ///jbay_reg.device_select.cbc.cbc_cbus.rb_creq_credit.rb_creq_credit_2_3
    rb_creq_credit_2_3: RbCreqCredit23 @ 0x8,
