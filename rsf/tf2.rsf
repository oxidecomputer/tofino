///main.device_select.cbc.cbc_lq_fm_dr
block CbcLqFmDr {
    ///jbay_reg.device_select.cbc.cbc_lq_fm_dr.ctrl
    ctrl: CbcLqFmDr_Ctrl @ 0x0,
    ///jbay_reg.device_select.cbc.cbc_lq_fm_dr.base_addr_low
    base_addr_low: CbcLqFmDr_BaseAddrLow @ 0x4,
    ///jbay_reg.device_select.cbc.cbc_lq_fm_dr.base_addr_high
    base_addr_high: CbcLqFmDr_BaseAddrHigh @ 0x8,
    ///jbay_reg.device_select.cbc.cbc_lq_fm_dr.limit_addr_low
    limit_addr_low: CbcLqFmDr_LimitAddrLow @ 0xc,
    ///jbay_reg.device_select.cbc.cbc_lq_fm_dr.limit_addr_high
    limit_addr_high: CbcLqFmDr_LimitAddrHigh @ 0x10,
    ///jbay_reg.device_select.cbc.cbc_lq_fm_dr.size
    size: CbcLqFmDr_Size @ 0x14,
    ///jbay_reg.device_select.cbc.cbc_lq_fm_dr.head_ptr
    head_ptr: CbcLqFmDr_HeadPtr @ 0x18,
    ///jbay_reg.device_select.cbc.cbc_lq_fm_dr.tail_ptr
    tail_ptr: CbcLqFmDr_TailPtr @ 0x1c,
    ///jbay_reg.device_select.cbc.cbc_lq_fm_dr.ring_timeout
    ring_timeout: CbcLqFmDr_RingTimeout @ 0x20,
    ///jbay_reg.device_select.cbc.cbc_lq_fm_dr.data_timeout
    data_timeout: CbcLqFmDr_DataTimeout @ 0x24,
    ///jbay_reg.device_select.cbc.cbc_lq_fm_dr.status
    status: CbcLqFmDr_Status @ 0x28,
    ///jbay_reg.device_select.cbc.cbc_lq_fm_dr.empty_int_time
    empty_int_time: CbcLqFmDr_EmptyIntTime @ 0x2c,
    ///jbay_reg.device_select.cbc.cbc_lq_fm_dr.empty_int_count
    empty_int_count: CbcLqFmDr_EmptyIntCount @ 0x30,
}

