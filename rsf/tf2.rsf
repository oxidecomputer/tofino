///main.device_select.lfltr[0]
block Lfltr {
    ///hash
    hash: Lfltr_Hash[0x4; 0x8000] @ 0x0,
    ///ctrl
    ctrl: Ctrl @ 0x20000,
}

///main.device_select.lfltr[0].ctrl
block Ctrl {
    ///jbay_reg.device_select.lfltr.ctrl.scratch
    scratch: Ctrl_Scratch[0x4; 0x4] @ 0x0,
    ///jbay_reg.device_select.lfltr.ctrl.dft_csr
    dft_csr: Ctrl_DftCsr @ 0x10,
    ///jbay_reg.device_select.lfltr.ctrl.common_ctrl
    common_ctrl: Ctrl_CommonCtrl @ 0x14,
    ///jbay_reg.device_select.lfltr.ctrl.lqt_timeout
    lqt_timeout: LqtTimeout @ 0x18,
    ///jbay_reg.device_select.lfltr.ctrl.bft_ctrl
    bft_ctrl: BftCtrl @ 0x1c,
    ///jbay_reg.device_select.lfltr.ctrl.hash_seed
    hash_seed: Ctrl_HashSeed[0x4; 0x4] @ 0x20,
    ///jbay_reg.device_select.lfltr.ctrl.intr_stat
    intr_stat: Ctrl_IntrStat @ 0x30,
    ///jbay_reg.device_select.lfltr.ctrl.intr_en0
    intr_en0: Ctrl_IntrEn0 @ 0x34,
    ///jbay_reg.device_select.lfltr.ctrl.intr_en1
    intr_en1: Ctrl_IntrEn1 @ 0x38,
    ///jbay_reg.device_select.lfltr.ctrl.freeze_en
    freeze_en: Ctrl_FreezeEn @ 0x3c,
    ///jbay_reg.device_select.lfltr.ctrl.intr_inj
    intr_inj: Ctrl_IntrInj @ 0x40,
    ///lq_sop_in
    lq_sop_in: LqSopIn @ 0x48,
    ///lq_eop_in_err
    lq_eop_in_err: LqEopInErr @ 0x50,
    ///lq_in
    lq_in: LqIn @ 0x58,
    ///lq_dropped_state
    lq_dropped_state: LqDroppedState @ 0x60,
    ///lq_dropped_learned
    lq_dropped_learned: LqDroppedLearned @ 0x68,
    ///lq_learned
    lq_learned: LqLearned @ 0x70,
    ///jbay_reg.device_select.lfltr.ctrl.pbe_log
    pbe_log: PbeLog @ 0x78,
    ///jbay_reg.device_select.lfltr.ctrl.sbe_log
    sbe_log: Ctrl_SbeLog @ 0x7c,
    ///jbay_reg.device_select.lfltr.ctrl.mbe_log
    mbe_log: Ctrl_MbeLog @ 0x80,
    ///jbay_reg.device_select.lfltr.ctrl.bft_state
    bft_state: BftState @ 0x84,
    ///jbay_reg.device_select.lfltr.ctrl.lqt_state
    lqt_state: LqtState @ 0x88,
    ///jbay_reg.device_select.lfltr.ctrl.creq_state
    creq_state: CreqState @ 0x8c,
    ///jbay_reg.device_select.lfltr.ctrl.debug_bus_ctrl
    debug_bus_ctrl: Ctrl_DebugBusCtrl @ 0x90,
}

