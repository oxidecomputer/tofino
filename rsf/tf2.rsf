    flush: MbcMbus_Flush @ 0x18,
    ///jbay_reg.device_select.mbc.mbc_mbus.link_down
    link_down: MbcMbus_LinkDown @ 0x1c,
    ///baresync_ts_set_value
    baresync_ts_set_value: BaresyncTsSetValue @ 0x20,
    ///baresync_ts_inc
