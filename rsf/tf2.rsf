register<32> OutEgr_Cfg48Mask {
    ///cfg
    cfg: rw b20 @ 0x0,
}

///Configuration Data for cfg48 counters.
register<32> OutEgr_Cfg48Data {
    ///cfg
    cfg: rw b20 @ 0x0,
}

///Input data selector for cfg48 counters.
register<32> OutEgr_Cfg48DataSel {
    ///cfg
    cfg: rw b4 @ 0x0,
}